{
  "name": "team-task-manager",
  "private": true,
  "version": "1.0.0",
  "workspaces": [
    "client",
    "server"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "npm run build --workspace client && npm run prisma:generate --workspace server",
    "prisma:generate": "npm run prisma:generate --workspace server",
    "prisma:migrate:deploy": "npm run prisma:migrate:deploy --workspace server",
    "start": "npm start --workspace server"
  }
}
